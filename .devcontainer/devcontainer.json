{
  "name": "cortado-dev",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {}
  },
  "postCreateCommand": "cd proto && buf generate && cd ../flutter && flutter pub get",
  "remoteEnv": {
    "CORTADO_ENV": "development"
  },
  "forwardPorts": [8080, 9090, 9731, 3001],
  "customizations": {
    "vscode": {
      "extensions": [
        "golang.go",
        "dart-code.dart-code",
        "dart-code.flutter",
        "hashicorp.terraform"
      ]
    }
  }
}

